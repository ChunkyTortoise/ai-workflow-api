# .claudeignore — tells Claude Code not to explore these paths

# Python artifacts
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.ruff_cache/

# Dependencies
.venv/
venv/
env/

# Lock files
poetry.lock
requirements.lock
Pipfile.lock

# Redis dump
dump.rdb

# Environment and secrets
.env
.env.*

# Generated outputs
logs/
*.log
celerybeat-schedule
celerybeat.pid

# IDE
.idea/
.vscode/
